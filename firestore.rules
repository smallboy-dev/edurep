rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sessions collection - allow read/write access
    match /sessions/{sessionId} {
      allow read, write: if true; // Allow all access for testing
      
      // In production, you might want more restrictive rules:
      // allow read: if request.time < resource.data.expiresAt;
      // allow write: if request.time < resource.data.expiresAt;
      // allow create: if request.auth != null;
    }
    
    // Allow read/write access to any document for testing
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
